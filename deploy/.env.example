DIGITAL_TWIN_ENVIRONMENT=production
DIGITAL_TWIN_SERVER_PORT=8080
DIGITAL_TWIN_SERVER_API_KEY=change-me-local-api-key
DIGITAL_TWIN_LOG_LEVEL=info
DIGITAL_TWIN_TENANT_DEFAULT_ID=default

# Default deployment profile stays local/mock-first.
DIGITAL_TWIN_TTS_PROVIDER=local
DIGITAL_TWIN_ASR_PROVIDER=local

# HTTP TTS provider shape. Leave commented until a real provider is chosen.
# DIGITAL_TWIN_TTS_PROVIDER=http
# DIGITAL_TWIN_TTS_BASE_URL=https://tts.example.test/synthesize
# DIGITAL_TWIN_TTS_API_KEY=replace-with-provider-key
